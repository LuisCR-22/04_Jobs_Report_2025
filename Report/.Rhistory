# Process the deciles and gini data for final Tableau format
# Author: Luis Castellanos - Stats Team
# Date: 2025-06-06
rm(list = ls())  # Clear the workspace
gc()  # Garbage collection
# Load required libraries
library(readxl)
library(writexl)
library(dplyr)
# Set the file path (same as original code)
file_path <- "C:/Users/wb593225/WBG/LAC Team for Statistical Development - WB Group - Documents/General/FY2025/Semiannual_Report/May/excel/Outputs/13 Dashboard data"
# Read the input file created by the previous script
input_file <- file.path(file_path, "21_Deciles_gini_Tableau_format.xlsx")
# Read both sheets
data <- read_excel(input_file, sheet = "Data")
description <- read_excel(input_file, sheet = "Description")
cat("Original data loaded. Rows:", nrow(data), "\n")
# 1. Delete all indicators related to "Mean Labor Income per capita by Decile"
data_filtered <- data %>%
filter(!grepl("Mean Labor Income per capita by Decile", Indicator, ignore.case = TRUE))
cat("After filtering out per capita indicators. Rows:", nrow(data_filtered), "\n")
cat("Rows removed:", nrow(data) - nrow(data_filtered), "\n")
# 2. For all variables related to "income" round the values to 1 decimal
# 3. Multiply gini variables by 100 and round to 1 decimal
# 4. For wage by decile values, round to 2 decimals
data_processed <- data_filtered %>%
mutate(
Value = case_when(
# Gini variables: multiply by 100 and round to 1 decimal
grepl("gini", Indicator, ignore.case = TRUE) ~ round(Value * 100, 1),
# Wage by decile: round to 2 decimals
grepl("Mean Wage by Decile", Indicator, ignore.case = TRUE) ~ round(Value, 2),
# Other income variables: round to 1 decimal
grepl("income", Indicator, ignore.case = TRUE) ~ round(Value, 1),
# All others: keep as is
TRUE ~ Value
)
)
# Update the description to reflect changes
description_updated <- description %>%
add_row(
Section = "Processing Note",
Description = "Post-processed on 2025-06-06: Removed Mean Labor Income per capita by Decile indicators. Applied rounding: income variables (1 decimal), gini coefficients (multiplied by 100, 1 decimal), wage by decile (2 decimals)."
)
# 6. Save the output as "22_deciles_gini_long_tableau.xlsx"
output_file <- file.path(file_path, "22_deciles_gini_long_tableau.xlsx")
# Prepare the list of sheets for the Excel file
sheets_list <- list(
"Data" = data_processed,
"Description" = description_updated
)
# Save the processed file
write_xlsx(sheets_list, path = output_file)
cat("✅ Processed file saved to:", output_file, "\n")
# Display processing summary
cat("\nProcessing Summary:\n")
cat("Original rows:", nrow(data), "\n")
cat("Final rows:", nrow(data_processed), "\n")
cat("Rows removed (per capita indicators):", nrow(data) - nrow(data_processed), "\n")
# Show how processing affected different indicator types
processing_summary <- data_processed %>%
group_by(Indicator) %>%
summarize(
count = n(),
non_missing = sum(!is.na(Value)),
.groups = 'drop'
) %>%
arrange(Indicator)
cat("\nIndicators in final dataset:\n")
print(processing_summary)
